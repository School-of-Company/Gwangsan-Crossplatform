{
  "name": "my-expo-app",
  "version": "1.0.0",
  "scripts": {
    "android": "expo run:android",
    "ios": "expo run:ios",
    "start": "expo start",
    "prebuild": "expo prebuild",
    "test": "jest --watchAll=false",
    "test:watch": "jest --watchAll",
    "test:coverage": "jest --coverage",
    "lint": "eslint \"**/*.{js,jsx,ts,tsx}\" && prettier -c \"**/*.{js,jsx,ts,tsx,json}\"",
    "format": "eslint \"**/*.{js,jsx,ts,tsx}\" --fix && prettier \"**/*.{js,jsx,ts,tsx,json}\" --write",
    "web": "expo start --web",
    "e2e:build:ios": "detox build --configuration ios.sim.debug",
    "e2e:test:ios": "detox test --configuration ios.sim.debug",
    "e2e:build:android": "detox build --configuration android.emu.debug",
    "e2e:test:android": "detox test --configuration android.emu.debug",
    "e2e:build:ios:release": "detox build --configuration ios.sim.release",
    "e2e:test:ios:release": "detox test --configuration ios.sim.release --cleanup",
    "e2e:build:ios:coverage": "detox build --configuration ios.sim.coverage",
    "e2e:test:ios:coverage": "E2E_COVERAGE=true detox test --configuration ios.sim.coverage --cleanup --jest-runner-config jest.e2e.coverage.config.js",
    "e2e:coverage:report": "mkdir -p .nyc_output && cp coverage/e2e-coverage.json .nyc_output/ && nyc report",
    "e2e:test:ios:release:verbose": "detox test --configuration ios.sim.release --loglevel verbose",
    "e2e:build:android:release": "detox build --configuration android.emu.release",
    "e2e:test:android:release": "detox test --configuration android.emu.release --cleanup",
    "e2e:test:ios:debug": "detox test --configuration ios.sim.debug --loglevel verbose",
    "e2e:test:android:debug": "detox test --configuration android.emu.debug --loglevel verbose",
    "prepare": "husky"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@expo/ngrok": "^4.1.3",
    "@react-native-assets/slider": "^11.0.8",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "^12.0.1",
    "@sentry/react-native": "~7.2.0",
    "@tanstack/react-query": "^5.81.5",
    "@tanstack/react-query-devtools": "^5.81.5",
    "axios": "^1.15.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "clsx": "^2.1.1",
    "expo": "~54.0.29",
    "expo-constants": "~18.0.9",
    "expo-dev-client": "~6.0.20",
    "expo-device": "~8.0.10",
    "expo-file-system": "~19.0.21",
    "expo-image": "~3.0.11",
    "expo-image-picker": "~17.0.10",
    "expo-linking": "~8.0.10",
    "expo-local-authentication": "~17.0.8",
    "expo-notifications": "~0.32.15",
    "expo-router": "~6.0.19",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "immer": "^10.1.3",
    "nativewind": "latest",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-css-interop": "^0.2.1",
    "react-native-dotenv": "^3.4.11",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-image-picker": "^8.2.1",
    "react-native-keychain": "^10.0.0",
    "react-native-modal": "^14.0.0-rc.1",
    "react-native-pager-view": "6.9.1",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-toast-message": "^2.3.3",
    "react-native-vector-icons": "^10.2.0",
    "scrolloop": "^0.3.4",
    "socket.io-client": "^4.8.1",
    "whatwg-fetch": "^3.6.20",
    "zod": "^3.25.72",
    "zustand": "^5.0.6"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.1.13",
    "babel-plugin-istanbul": "^7.0.1",
    "detox": "^20.47.0",
    "eslint": "^9.25.1",
    "eslint-config-expo": "~10.0.0",
    "eslint-config-prettier": "^10.1.2",
    "eslint-import-resolver-babel-module": "^5.3.2",
    "eslint-plugin-security": "^4.0.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.17",
    "lint-staged": "^16.4.0",
    "msw": "^2.12.14",
    "nyc": "^18.0.0",
    "prettier": "^3.2.5",
    "prettier-plugin-tailwindcss": "^0.5.11",
    "react-test-renderer": "^19.1.0",
    "tailwindcss": "^3.4.0",
    "ts-jest": "^29.4.6",
    "typescript": "~5.9.2"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx}": "eslint --fix",
    "**/*.{js,jsx,ts,tsx,json}": "prettier --write"
  },
  "main": "expo-router/entry",
  "private": true,
  "overrides": {
    "react-native-worklets": "0.7.x"
  }
}
